{
  "name": "@onlook/repo",
  "version": "0.0.0",
  "description": "Onlook Monorepo",
  "homepage": "https://onlook.dev",
  "license": "Apache-2.0",
  "private": true,
  "author": {
    "name": "Onlook",
    "email": "contact@onlook.dev"
  },
  "workspaces": [
    "plugins/*",
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "build": "turbo build",
    "package": "turbo package",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "db:gen": "turbo db:gen --filter=@onlook/supabase",
    "db:gen:local": "turbo db:gen --filter=@onlook/backend",
    "dev": "turbo dev --parallel",
    "dev:backend": "turbo dev --filter=@onlook/backend",
    "dev:studio": "turbo dev --filter=@onlook/studio",
    "start:studio": "turbo start --filter=@onlook/studio",
    "test": "turbo test --parallel",
    "format": "prettier --write .",
    "lint": "turbo lint && bun lint:repo",
    "lint:repo": "bunx sherif@latest",
    "lint:repo:fix": "bunx sherif@latest --fix",
    "typecheck": "turbo typecheck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onlook-dev/onlook.git"
  },
  "bugs": {
    "url": "https://github.com/onlook-dev/onlook/issues"
  },
  "devDependencies": {
    "lefthook": "^1.7.15",
    "turbo": "2.1.1",
    "typescript": "^5.5.4"
  },
  "packageManager": "bun@1.1.29"
}
